{
  "name": "backend",
  "version": "1.0.0",
  "description": "",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "seed": "prisma db seed --schema=./database/prisma/schema.prisma",
    "prisma:migrate:dev": "prisma migrate dev --schema=./database/prisma/schema.prisma",
    "prisma:generate": "prisma generate --schema=./database/prisma/schema.prisma",
    "prisma:push": "prisma db push --schema=./database/prisma/schema.prisma --accept-data-loss",
    "prisma:migrate:deploy": "prisma migrate deploy --schema=./database/prisma/schema.prisma"
  },
  "postinstall": "prisma generate --schema=./database/prisma/schema.prisma",
  "keywords": [],
  "prisma": {
    "seed": "ts-node database/prisma/seed.ts"
  },
  "author": "",
