generator client {
  provider = "prisma-client-js"
  output   = "../../node_modules/.prisma/client"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
}

model User {
  id           Int       @id @default(autoincrement())
  firstName    String    @default("")
  lastName     String    @default("")
  email        String    @unique
  passwordHash String

  phone        String?
  avatar       String?
  bio          String?

  institution      String?
  institutionType  String?
  city             String?
  state            String?

  notificationsEnabled Boolean @default(true)
  theme                String  @default("ember")

  upiId        String?
  googleId     String?   @unique
  authProvider String    @default("local")

  saleNotifications    Boolean @default(true)
  messageNotifications Boolean @default(true)
  priceDropAlerts      Boolean @default(true)
  profileComplete      Boolean @default(true)
  sellerIdVerified     Boolean @default(false)
  sellerVideoVerified  Boolean @default(false)
  sellerVerificationExpiresAt DateTime?
  createdAt    DateTime  @default(now())

  items            Item[]
  sentMessages     Message[]      @relation("SentMessages")
  receivedMessages Message[]      @relation("ReceivedMessages")
  buyerTxns        Transaction[]  @relation("BuyerTransactions")
  sellerTxns       Transaction[]  @relation("SellerTransactions")
  cartItems        CartItem[]
  notifications    Notification[]
  otpCodes         OtpCode[]
  watchedItems     WatchedItem[]
  sentRequests     ChatRequest[]  @relation("SentRequests")
  receivedRequests ChatRequest[]  @relation("ReceivedRequests")
  reviewsGiven     Review[]       @relation("ReviewsGiven")
  reviewsReceived  Review[]       @relation("ReviewsReceived")
  checkoutSessions CheckoutSession[]
}

model Item {
  id          Int      @id @default(autoincrement())
  title       String
  description String?
  price       Float
  category    String
  subcategory String?
  condition   String
  status      String   @default("available")
  quantity    Int      @default(1)
  specs       Json?
  purchaseYear Int?
  expiryDate   DateTime?
  madeOn       DateTime?
  createdAt    DateTime @default(now())

  imageUrl    String?
  images      String[]

  sellerInstitution     String?
  sellerInstitutionType String?
  sellerCity            String?
  sellerState           String?

  sellerId    Int
  seller      User          @relation(fields: [sellerId], references: [id])

  messages      Message[]
  chatRequests  ChatRequest[]
  transactions  Transaction[]
  cartItems     CartItem[]
  notifications Notification[]
  watchedBy     WatchedItem[]
  checkoutSessions CheckoutSession[]
}

model WatchedItem {
  id           Int      @id @default(autoincrement())
  userId       Int
  itemId       Int
  priceAtWatch Float
  createdAt    DateTime @default(now())

  user         User @relation(fields: [userId], references: [id], onDelete: Cascade)
  item         Item @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@unique([userId, itemId])
}

model Message {
  id         Int      @id @default(autoincrement())
  content    String?
  imageUrl   String?
  fileUrl    String?
  fileType   String?  // 'image', 'video', 'pdf'
  fileName   String?
  fileSize   Int?
  publicId   String?
  expiresAt  DateTime?
  isCloudDeleted Boolean @default(false)
  
  createdAt  DateTime @default(now())
  read       Boolean  @default(false)

  deletedBySender   Boolean @default(false)
  deletedByReceiver Boolean @default(false)

  senderId   Int
  receiverId Int
  itemId     Int?

  sender     User  @relation("SentMessages",     fields: [senderId],   references: [id])
  receiver   User  @relation("ReceivedMessages",  fields: [receiverId], references: [id])
  item       Item? @relation(fields: [itemId],   references: [id], onDelete: Cascade)
}

model Transaction {
  id           Int      @id @default(autoincrement())
  status       String   @default("pending")
  paymentMethod String  @default("upi_direct")
  paymentStatus String  @default("pending")
  safetyTier    String  @default("minimal")
  qrPayload     String?
  pinCodeHash   String?
  pinAttempts   Int     @default(0)
  pinConfirmedAt DateTime?
  paidAt        DateTime?
  razorpayOrderId   String?
  razorpayPaymentId String?
  razorpaySignature String?
  createdAt    DateTime @default(now())

  quantity     Int      @default(1)
  price        Float    @default(0)
  itemTitle    String   @default("")
  itemCategory String   @default("")

  itemId    Int?
  buyerId   Int
  sellerId  Int

  item      Item? @relation(fields: [itemId],    references: [id], onDelete: SetNull)
  buyer     User  @relation("BuyerTransactions",  fields: [buyerId],  references: [id])
  seller    User  @relation("SellerTransactions", fields: [sellerId], references: [id])

  review    Review?
  checkoutSession CheckoutSession?
}

model CheckoutSession {
  id               Int      @id @default(autoincrement())
  idempotencyKey   String   @unique
  status           String   @default("initialized")
  paymentMethod    String   @default("upi_direct")
  subtotal         Float    @default(0)
  platformFee      Float    @default(0)
  paymentGatewayFee Float   @default(0)
  gstOnFees        Float    @default(0)
  totalPayable     Float    @default(0)
  currency         String   @default("INR")
  displayPin       String?
  upiIntent        String?
  qrPayload        String?
  expiresAt        DateTime
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  userId           Int
  itemId           Int
  transactionId    Int?     @unique

  user             User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  item             Item        @relation(fields: [itemId], references: [id], onDelete: Cascade)
  transaction      Transaction? @relation(fields: [transactionId], references: [id], onDelete: SetNull)

  @@index([userId, itemId, status, expiresAt])
}

model CartItem {
  id        Int      @id @default(autoincrement())
  quantity  Int      @default(1)
  createdAt DateTime @default(now())

  userId    Int
  itemId    Int

  user      User @relation(fields: [userId], references: [id])
  item      Item @relation(fields: [itemId], references: [id])

  @@unique([userId, itemId])
}

model Notification {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now())
  type      String   @default("sale")
  userId    Int
  itemId    Int?
  itemTitle String   @default("")
  buyerName String   @default("")
  price     Float    @default(0)
  oldPrice  Float?
  message   String   @default("")
  seen      Boolean  @default(false)

  user      User  @relation(fields: [userId], references: [id])
  item      Item? @relation(fields: [itemId], references: [id], onDelete: SetNull)
}

model OtpCode {
  id        Int      @id @default(autoincrement())
  userId    Int
  code      String
  type      String
  newEmail  String?
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  user      User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model SuggestedInstitution {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  city      String?
  state     String?
  type      String   @default("college")
  count     Int      @default(1)
  createdAt DateTime @default(now())
}

model ChatRequest {
  id         Int      @id @default(autoincrement())
  senderId   Int
  receiverId Int
  itemId     Int?                          // null = profile-based, set = item-based
  status     String   @default("pending")
  message    String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  declinedAt DateTime?

  deletedBySender   Boolean @default(false)
  deletedByReceiver Boolean @default(false)
  
  sender   User  @relation("SentRequests",     fields: [senderId],   references: [id], onDelete: Cascade)
  receiver User  @relation("ReceivedRequests", fields: [receiverId], references: [id], onDelete: Cascade)
  item     Item? @relation(fields: [itemId],   references: [id],     onDelete: Cascade)

  @@unique([senderId, receiverId, itemId])
}

model Review {
  id            Int      @id @default(autoincrement())
  rating        Int
  comment       String?
  createdAt     DateTime @default(now())

  reviewerId    Int
  revieweeId    Int
  transactionId Int      @unique

  reviewer    User        @relation("ReviewsGiven",    fields: [reviewerId],    references: [id], onDelete: Cascade)
  reviewee    User        @relation("ReviewsReceived", fields: [revieweeId],    references: [id], onDelete: Cascade)
  transaction Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
}