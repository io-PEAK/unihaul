  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register Buyer",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"{{buyerFirstName}}\",\n  \"lastName\": \"{{buyerLastName}}\",\n  \"email\": \"{{buyerEmail}}\",\n  \"password\": \"{{buyerPassword}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/register",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "register"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "const token = json.token || json.accessToken || json.jwt;",
                  "if (token) pm.environment.set('tokenBuyer', token);"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
