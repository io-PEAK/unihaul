{
  "info": {
    "_postman_id": "d6bc532f-bab5-4d7a-8793-35db7f94f77b",
    "name": "Student Shop APIs",
    "description": "Single collection with grouped folders for Auth, Items, Transactions, Notifications, and Sales Flow.",
