    {
      "name": "Items",
      "item": [
        {
          "name": "Get All Items",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/items",
              "host": ["{{baseUrl}}"],
              "path": ["items"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "const first = Array.isArray(json) ? json[0] : (Array.isArray(json.items) ? json.items[0] : null);",
                  "if (first?.id) pm.environment.set('itemId', String(first.id));"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Get Item By ID",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/items/{{itemId}}",
              "host": ["{{baseUrl}}"],
              "path": ["items", "{{itemId}}"]
            }
          }
        }
      ]
    },
    {
      "name": "Transactions",
      "item": [
        {
          "name": "Quote",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{tokenBuyer}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"itemId\": {{itemId}},\n  \"paymentMethod\": \"upi_direct\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/transactions/quote",
              "host": ["{{baseUrl}}"],
              "path": ["transactions", "quote"]
            }
          }
        },
        {
          "name": "Checkout",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{tokenBuyer}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"itemId\": {{itemId}},\n  \"paymentMethod\": \"upi_direct\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/transactions/checkout",
              "host": ["{{baseUrl}}"],
              "path": ["transactions", "checkout"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "const tx = json.transactionId || json.transaction?.id;",
                  "if (tx) pm.environment.set('transactionId', String(tx));"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Verify Razorpay (optional)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{tokenBuyer}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"transactionId\": {{transactionId}},\n  \"razorpayOrderId\": \"replace_me\",\n  \"razorpayPaymentId\": \"replace_me\",\n  \"razorpaySignature\": \"replace_me\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/transactions/razorpay/verify",
              "host": ["{{baseUrl}}"],
              "path": ["transactions", "razorpay", "verify"]
            }
          }
        },
        {
          "name": "Get My Transactions (Buyer)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{tokenBuyer}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/transactions",
              "host": ["{{baseUrl}}"],
              "path": ["transactions"]
            }
          }
        },
        {
          "name": "Get Transaction By ID (Buyer)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{tokenBuyer}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/transactions/{{transactionId}}",
              "host": ["{{baseUrl}}"],
              "path": ["transactions", "{{transactionId}}"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "const otp = json.deliveryOtp || json.delivery_otp || json.checkoutSession?.displayPin;",
                  "if (otp) pm.environment.set('deliveryOtp', String(otp));"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Seller Schedule Handoff",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{tokenSeller}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"scheduledAt\": \"{{scheduledAt}}\",\n  \"windowHours\": {{windowHours}}\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/transactions/{{transactionId}}/handoff-schedule",
              "host": ["{{baseUrl}}"],
              "path": ["transactions", "{{transactionId}}", "handoff-schedule"]
            }
          }
        },
        {
          "name": "Seller Confirm OTP",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{tokenSeller}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"pin\": \"{{deliveryOtp}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/transactions/{{transactionId}}/confirm-pin",
              "host": ["{{baseUrl}}"],
              "path": ["transactions", "{{transactionId}}", "confirm-pin"]
            }
          }
        }
      ]
